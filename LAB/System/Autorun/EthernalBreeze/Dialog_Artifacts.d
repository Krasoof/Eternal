	var int itm1, var int itm2, var int itm3, var int count1, var int count2, var int count3)
{
	StExt_AddAtrifactStat(artifactId, statName, statValue, itm1, itm2, itm3, count1, count2, count3);
	
	if (artifactId == StExt_ArtifactIndex_Grimoir) { Dia_StExt_ModMenu_Artifact_Grimoire_info(); }
	else if (artifactId == StExt_ArtifactIndex_Dagger) { Dia_StExt_ModMenu_Artifact_Dagger_info(); }
	else
	{
		StExt_PrintDebugStack("StExt_AddAtrifactStat_Dia() -> incorrect artifact type!");
		Dia_StExt_ModMenu_ExitDialog_info();
	};
};

