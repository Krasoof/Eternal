func void StExt_BuildArtifact_StatChoice(var int artType, var string statName, var int statVal, var int statMax)
{
	var int statId;
	var int statNow;
	var string choiceName;
	var string choiceAction;
	var string artStatsArray;
	var string choiceAfix;
	var string statBonus;
	
	if(!StExt_SymbolExist(statName))
	{
		StExt_PrintDebugStack(concatstrings("StExt_BuildArtifact_StatChoice() -> incorrect statName: ", statName));
		return;
	};
	
	statId = StExt_GetIntValueByName(statName);
	if ((statId <= StExt_Null) || (statId >= StExt_PcStats_Index_Max))
	{
		StExt_PrintDebugStack(concatstrings("StExt_BuildArtifact_StatChoice() -> incorrect statId: ", inttostring(statId)));
		return;
	};
	
	if (artType == StExt_ArtifactIndex_Grimoir) 
	{ 
		artStatsArray = "StExt_PcStats_Grimoir";
		choiceAfix = "Grimoir";
	}
	else if (artType == StExt_ArtifactIndex_Dagger)
	{ 
		artStatsArray = "StExt_PcStats_Dagger";
		choiceAfix = "Dagger";
	}
	else
	{
		StExt_PrintDebugStack("StExt_BuildArtifact_StatChoice() -> incorrect artifact type!");
		return;
	};
	
	statNow = StExt_Array_GetInt(artStatsArray, statId);
	if (statNow >= statMax) { return; };
	
	StExt_StatValueToString(statId, statVal);
	choiceName = StExt_Array_GetString("StExt_PcStats_Desc", statId);
	choiceName = concatstrings(choiceName, " +");
	choiceName = concatstrings(choiceName, StExt_ReturnString);
	
	choiceAction = "StExt_Dia_AddArtifactStat_";
	choiceAction = concatstrings(choiceAction, choiceAfix);
	choiceAction = concatstrings(choiceAction, "_");
	choiceAction = concatstrings(choiceAction, inttostring(statId));
	
	if (artType == StExt_ArtifactIndex_Grimoir) { StExt_Info_AddChoice(Dia_StExt_ModMenu_Artifact_Grimoire, choiceName, choiceAction); }
	else if (artType == StExt_ArtifactIndex_Dagger) { StExt_Info_AddChoice(Dia_StExt_ModMenu_Artifact_Dagger, choiceName, choiceAction); };	
};

func string StExt_BuildArtifactResetString(var int artType)
{
	var string result;
	result = StExt_Str_Config_ArtifactReset;
	result = concatstrings(result, StExt_Str_NeedGold);
	result = concatstrings(result, inttostring(StExt_GetResetArtifactCost(artType)));
	result = concatstrings(result, ")");
	return result;
};

